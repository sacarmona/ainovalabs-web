---
/*
  Header de páginas interiores. Fondo con la tonalidad del logo:
  base azul noche más profunda + resplandor turquesa (izq.) y azul acero (der.)
  + grilla sutil. El slot "fx" permite montar una capa animada (ej. WaveFX).
*/
interface Props {
  title: string;
  intro: string;
}
const { title, intro } = Astro.props;
---

<section class="relative overflow-hidden pb-16 pt-40 md:pb-24 md:pt-48">
  <!-- base más oscura con tinte del logo -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#03141c] via-navy-950 to-navy-950" aria-hidden="true"></div>

  <!-- resplandores turquesa y azul acero (degradado del logo) -->
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(640px 320px at 16% 8%, rgba(62, 199, 166, 0.16), transparent 70%),
      radial-gradient(720px 360px at 88% 30%, rgba(46, 127, 168, 0.22), transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- grilla sutil -->
  <div
    class="absolute inset-0 opacity-[0.08]"
    style="background-image: linear-gradient(rgba(62,199,166,.5) 1px, transparent 1px), linear-gradient(90deg, rgba(62,199,166,.5) 1px, transparent 1px); background-size: 72px 72px; mask-image: radial-gradient(ellipse 85% 80% at 50% 0%, black 20%, transparent 75%);"
    aria-hidden="true"
  ></div>

  <slot name="fx" />

  <div class="relative z-10 mx-auto max-w-4xl px-5 md:px-8">
    <h1 class="reveal font-display text-4xl font-bold leading-tight md:text-6xl">{title}</h1>
    <p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-ink-300">{intro}</p>
  </div>
</section>
