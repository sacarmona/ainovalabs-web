---
/*
  Logo AI-NOVA recreado en SVG a partir del logo oficial:
  isotipo "AI" con nodos de circuito en degradado turquesa→azul (#3EC7A6 → #2E7FA8)
  y wordmark "AI-NOVA" (aproximado con Days One).
  `tone: 'dark'` = wordmark blanco para fondos oscuros (por defecto);
  `tone: 'light'` = wordmark azul marino oficial (#003E6C) para fondos claros.
*/
interface Props {
  tone?: 'dark' | 'light';
  size?: number;
}
const { tone = 'dark', size = 36 } = Astro.props;
const gid = `ainova-g-${Math.random().toString(36).slice(2, 7)}`;
---

<span class="inline-flex items-center gap-2.5">
  <svg width={size} height={size} viewBox="0 0 96 96" fill="none" aria-hidden="true">
    <defs>
      <linearGradient id={gid} x1="76" y1="8" x2="16" y2="88" gradientUnits="userSpaceOnUse">
        <stop stop-color="#3EC7A6" />
        <stop offset="1" stop-color="#2E7FA8" />
      </linearGradient>
    </defs>
    <!-- marco exterior -->
    <rect x="8" y="8" width="76" height="76" rx="16" stroke={`url(#${gid})`} stroke-width="7" />
    <!-- bisel interior -->
    <rect x="20" y="20" width="52" height="52" rx="4" stroke={`url(#${gid})`} stroke-width="2.5" />
    <!-- A (la pierna izquierda sale del marco, como en el original) -->
    <path d="M13 89 L41 27 L55 63" stroke={`url(#${gid})`} stroke-width="7" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M31.5 57 H49.5" stroke={`url(#${gid})`} stroke-width="6" stroke-linecap="round" />
    <!-- traza inferior + I -->
    <path d="M45 70 H64 V38" stroke={`url(#${gid})`} stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M64 38 L68.5 30" stroke={`url(#${gid})`} stroke-width="5" stroke-linecap="round" />
    <circle cx="45" cy="70" r="5.5" fill={`url(#${gid})`} />
    <circle cx="70" cy="27" r="6" fill={`url(#${gid})`} />
  </svg>
  <span
    class="font-logo text-lg tracking-[0.06em]"
    style={`color: ${tone === 'light' ? '#003E6C' : '#ffffff'}`}
  >AI-NOVA</span>
</span>
