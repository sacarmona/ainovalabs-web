---
import t from '../content/i18n/es.json';

const icons: Record<string, string> = {
  target: 'M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0-18 0 M12 12m-5 0a5 5 0 1 0 10 0a5 5 0 1 0-10 0 M12 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0-2 0',
  flask: 'M9 3h6 M10 3v6l-5.5 9.5A2 2 0 0 0 6.24 21h11.52a2 2 0 0 0 1.74-2.5L14 9V3 M7.5 15h9',
  cog: 'M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0-6 0 M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z',
  chart: 'M3 3v18h18 M7 15l4-6 4 3 5-8',
  handshake: 'M4 17l5 5 7-7 M2 12l7-7 4 4 M13 9l4-4 5 5-4 4 M11 14l3 3',
  rocket: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0 M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5',
};
---

<section class="bg-navy-900/40 py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold md:text-5xl">{t.method.title}</h2>
      <p class="mt-4 text-lg text-ink-300">{t.method.subtitle}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {t.method.items.map((item) => (
        <div class="reveal rounded-2xl border border-white/10 bg-white/[0.03] p-7 transition hover:border-accent-500/50 hover:bg-white/[0.05]">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-accent-500/15 text-accent-400">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={icons[item.icon]} />
            </svg>
          </span>
          <h3 class="mt-5 font-display text-xl font-bold">{item.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-ink-400">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
