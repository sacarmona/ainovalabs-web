---
/*
  Animación para Robótica: brazo robótico estilo blueprint (plano técnico)
  que se articula lentamente — hombro, codo y pinza oscilan a distinto ritmo
  (rotaciones SMIL anidadas alrededor de cada articulación). Incluye guías
  punteadas de rango de movimiento y LED de estado parpadeante.
  Solo SVG + CSS, colores de marca. Capa de fondo, lado derecho.
*/
---

<div class="robotfx" aria-hidden="true">
  <svg viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice" fill="none">
    <defs>
      <linearGradient id="robot-g" x1="750" y1="120" x2="1050" y2="450" gradientUnits="userSpaceOnUse">
        <stop stop-color="#3EC7A6" />
        <stop offset="1" stop-color="#2E7FA8" />
      </linearGradient>
    </defs>

    <!-- guías blueprint: rango de movimiento y crucetas -->
    <g stroke="#3EC7A6" opacity="0.22">
      <path d="M 795 275 A 185 185 0 0 1 1010 265" stroke-width="1" stroke-dasharray="4 8" />
      <circle cx="900" cy="400" r="46" stroke-width="1" stroke-dasharray="3 7" />
      <path d="M 870 400 H 930 M 900 370 V 430" stroke-width="0.8" />
      <path d="M 900 452 H 1060 M 1060 446 V 458" stroke-width="0.8" stroke-dasharray="5 5" />
    </g>

    <!-- brazo articulado -->
    <g stroke="url(#robot-g)" stroke-linecap="round" stroke-linejoin="round">
      <!-- pedestal -->
      <path d="M 855 452 H 945 M 870 452 L 882 415 M 930 452 L 918 415" stroke-width="5" />

      <!-- hombro: oscila alrededor de (900,400) -->
      <g>
        <animateTransform attributeName="transform" type="rotate"
          values="0 900 400; -9 900 400; 4 900 400; 0 900 400"
          keyTimes="0; 0.35; 0.75; 1" dur="14s" repeatCount="indefinite"
          calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1; 0.45 0 0.55 1" />
        <path d="M 900 400 L 830 260" stroke-width="6" />
        <circle cx="900" cy="400" r="12" stroke-width="4" />

        <!-- codo: oscila alrededor de (830,260) -->
        <g>
          <animateTransform attributeName="transform" type="rotate"
            values="0 830 260; 12 830 260; -7 830 260; 0 830 260"
            keyTimes="0; 0.4; 0.8; 1" dur="11s" repeatCount="indefinite"
            calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1; 0.45 0 0.55 1" />
          <path d="M 830 260 L 975 185" stroke-width="5" />
          <circle cx="830" cy="260" r="9" stroke-width="3.5" />

          <!-- muñeca + pinza: oscila alrededor de (975,185) -->
          <g>
            <animateTransform attributeName="transform" type="rotate"
              values="0 975 185; -14 975 185; 8 975 185; 0 975 185"
              keyTimes="0; 0.45; 0.85; 1" dur="8s" repeatCount="indefinite"
              calcMode="spline" keySplines="0.45 0 0.55 1; 0.45 0 0.55 1; 0.45 0 0.55 1" />
            <circle cx="975" cy="185" r="7" stroke-width="3" />
            <path d="M 975 185 L 1010 168 M 1010 168 L 1028 178 M 1010 168 L 1014 148" stroke-width="4" />
            <!-- LED de estado en la pinza -->
            <circle class="led" cx="975" cy="185" r="3" fill="#38BDF8" stroke="none" />
          </g>
        </g>
      </g>
    </g>

    <!-- nodos de datos flotando cerca del brazo -->
    <g fill="url(#robot-g)">
      <circle class="blink" cx="1090" cy="140" r="4" style="--delay: 0s" />
      <circle class="blink" cx="740"  cy="150" r="3" style="--delay: 2.3s" />
      <circle class="blink" cx="1120" cy="330" r="3.5" style="--delay: 4.6s" />
    </g>
  </svg>
</div>

<style>
  .robotfx {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, transparent, black 18%, black 85%, transparent);
  }
  .robotfx svg {
    width: 100%;
    height: 100%;
  }

  .led {
    animation: led-blink 2.2s ease-in-out infinite;
  }
  @keyframes led-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.2; }
  }

  .blink {
    opacity: 0.3;
    animation: node-blink 7s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes node-blink {
    0%, 40%   { opacity: 0.3; }
    55%       { opacity: 0.9; }
    70%, 100% { opacity: 0.3; }
  }

  /* la oscilación es SMIL (no se puede pausar por CSS): con reduced-motion
     se oculta la capa completa */
  @media (prefers-reduced-motion: reduce) {
    .robotfx {
      display: none;
    }
  }
</style>
