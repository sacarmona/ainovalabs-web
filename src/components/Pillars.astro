---
import t from '../content/i18n/es.json';
---

<section class="py-20 md:py-28">
  <div class="reveal mx-auto max-w-2xl px-5 text-center md:px-8">
    <h2 class="font-display text-3xl font-bold md:text-5xl">{t.pillars.title}</h2>
    <p class="mt-4 text-lg text-ink-300">{t.pillars.subtitle}</p>
  </div>

  <div class="mx-auto mt-14 flex max-w-7xl flex-col gap-8 px-5 md:px-8">
    {t.pillars.items.map((item) => (
      <article
        id={item.id}
        class="reveal group relative flex min-h-[70vh] items-end overflow-hidden rounded-3xl border border-white/10"
      >
        <img
          src={item.image}
          alt=""
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/60 to-navy-950/10" aria-hidden="true"></div>

        <div class="relative z-10 max-w-2xl p-8 md:p-14">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-400">{item.kicker}</p>
          <h3 class="mt-3 font-display text-3xl font-bold leading-tight md:text-5xl">{item.title}</h3>
          <p class="mt-4 text-base leading-relaxed text-ink-300 md:text-lg">{item.text}</p>
          <a
            href={item.href}
            class="mt-7 inline-flex items-center gap-2 rounded-full border border-white/25 px-6 py-3 text-sm font-semibold transition hover:border-white/60 hover:bg-white/10"
          >
            {item.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14m0 0l-6-6m6 6l-6 6" />
            </svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
