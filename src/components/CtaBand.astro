---
import t from '../content/i18n/es.json';
---

<section class="relative overflow-hidden py-24 md:py-32">
  <div class="absolute left-1/2 top-1/2 h-[420px] w-[820px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-500/15 blur-[130px]" aria-hidden="true"></div>

  <div class="reveal relative z-10 mx-auto max-w-3xl px-5 text-center md:px-8">
    <h2 class="font-display text-4xl font-bold md:text-6xl">{t.cta.title}</h2>
    <p class="mt-5 text-lg leading-relaxed text-ink-300">{t.cta.text}</p>
    <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/contacto"
        class="w-full rounded-full bg-accent-500 px-8 py-3.5 font-semibold text-white shadow-lg shadow-accent-500/30 transition hover:bg-accent-400 sm:w-auto"
      >
        {t.cta.primary}
      </a>
      <a
        href="/nosotros"
        class="w-full rounded-full border border-white/20 px-8 py-3.5 font-semibold transition hover:border-white/50 hover:bg-white/5 sm:w-auto"
      >
        {t.cta.secondary}
      </a>
    </div>
  </div>
</section>
