---
import t from '../content/i18n/es.json';
import Logo from './Logo.astro';
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-300"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8">
    <a href="/" class="flex items-center" aria-label="AI-NOVA Labs — Inicio">
      <Logo size={38} />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {t.nav.links.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-ink-300 transition-colors hover:text-white"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contacto"
        class="rounded-full bg-accent-500 px-5 py-2 text-sm font-semibold text-white transition hover:bg-accent-400"
      >
        {t.nav.cta}
      </a>
    </div>

    <button
      id="nav-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-ink-100 md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </nav>

  <div id="nav-mobile" class="hidden border-t border-white/10 bg-navy-900/95 px-5 pb-6 pt-3 backdrop-blur-md md:hidden">
    {t.nav.links.map((link) => (
      <a href={link.href} class="block py-3 text-base font-medium text-ink-100">
        {link.label}
      </a>
    ))}
    <a href="/contacto" class="mt-3 block rounded-full bg-accent-500 px-5 py-2.5 text-center font-semibold text-white">
      {t.nav.cta}
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav')!;
  const setBg = () => {
    const scrolled = window.scrollY > 24;
    nav.classList.toggle('bg-navy-950/85', scrolled);
    nav.classList.toggle('backdrop-blur-md', scrolled);
    nav.classList.toggle('border-b', scrolled);
    nav.classList.toggle('border-white/10', scrolled);
  };
  setBg();
  window.addEventListener('scroll', setBg, { passive: true });

  const toggle = document.getElementById('nav-toggle')!;
  const mobile = document.getElementById('nav-mobile')!;
  toggle.addEventListener('click', () => {
    const open = mobile.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
    if (!open) nav.classList.add('bg-navy-950/85', 'backdrop-blur-md');
  });
</script>
