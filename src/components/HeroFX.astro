---
/*
  Animación decorativa del hero: trazas de circuito (estilo PCB) con pulsos
  de luz que las recorren y encienden nodos. Solo SVG + CSS (sin JS),
  colores de marca, loop infinito, respeta prefers-reduced-motion.
  Se monta como capa absoluta detrás del contenido del hero.
*/
---

<div class="herofx" aria-hidden="true">
  <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" fill="none">
    <defs>
      <linearGradient id="fx-trace" x1="0" y1="0" x2="1440" y2="900" gradientUnits="userSpaceOnUse">
        <stop stop-color="#3EC7A6" />
        <stop offset="1" stop-color="#2E7FA8" />
      </linearGradient>
    </defs>

    <!-- trazas base -->
    <g class="traces" stroke="url(#fx-trace)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M -20 180 H 300 L 410 290 H 610" />
      <path d="M 1460 140 H 1150 L 1050 240 H 880" />
      <path d="M -20 560 H 220 L 330 450 H 500" />
      <path d="M 1460 640 H 1210 L 1100 530 H 950" />
      <path d="M 260 920 V 780 L 370 670 H 540" />
      <path d="M 1180 920 V 800 L 1070 690 H 930" />
      <path d="M 720 -20 V 90" />
    </g>

    <!-- pulsos de luz (mismas geometrías, dash animado) -->
    <g class="pulses" stroke="#38BDF8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path pathLength="100" style="--dur: 7s;  --delay: 0s"    d="M -20 180 H 300 L 410 290 H 610" />
      <path pathLength="100" style="--dur: 8s;  --delay: 2.2s"  d="M 1460 140 H 1150 L 1050 240 H 880" />
      <path pathLength="100" style="--dur: 9s;  --delay: 1.1s"  d="M -20 560 H 220 L 330 450 H 500" />
      <path pathLength="100" style="--dur: 7.5s; --delay: 3.6s" d="M 1460 640 H 1210 L 1100 530 H 950" />
      <path pathLength="100" style="--dur: 8.5s; --delay: 4.4s" d="M 260 920 V 780 L 370 670 H 540" />
      <path pathLength="100" style="--dur: 9.5s; --delay: 0.8s" d="M 1180 920 V 800 L 1070 690 H 930" />
      <path pathLength="100" style="--dur: 6s;  --delay: 5s"    d="M 720 -20 V 90" />
    </g>

    <!-- nodos en los extremos de las trazas -->
    <g class="nodes" fill="url(#fx-trace)">
      <circle cx="610" cy="290" r="6"  style="--delay: 0.4s" />
      <circle cx="880" cy="240" r="6"  style="--delay: 2.6s" />
      <circle cx="500" cy="450" r="5"  style="--delay: 1.5s" />
      <circle cx="950" cy="530" r="6"  style="--delay: 4s" />
      <circle cx="540" cy="670" r="5"  style="--delay: 4.8s" />
      <circle cx="930" cy="690" r="6"  style="--delay: 1.2s" />
      <circle cx="720" cy="90"  r="5"  style="--delay: 5.4s" />
      <!-- nodos secundarios en los quiebres -->
      <circle cx="300" cy="180" r="3.5" style="--delay: 0s" />
      <circle cx="1150" cy="140" r="3.5" style="--delay: 2.2s" />
      <circle cx="220" cy="560" r="3.5" style="--delay: 1.1s" />
      <circle cx="1210" cy="640" r="3.5" style="--delay: 3.6s" />
    </g>
  </svg>
</div>

<style>
  .herofx {
    position: absolute;
    inset: 0;
    opacity: 0.55;
    pointer-events: none;
  }
  .herofx svg {
    width: 100%;
    height: 100%;
  }

  .traces {
    opacity: 0.28;
  }

  /* pulso: segmento corto de luz que recorre la traza */
  .pulses path {
    stroke-dasharray: 7 93;
    stroke-dashoffset: 107;
    opacity: 0.9;
    animation: fx-pulse var(--dur, 8s) linear infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes fx-pulse {
    0%   { stroke-dashoffset: 107; }
    70%, 100% { stroke-dashoffset: 0; }
  }

  /* nodos que "se encienden" cuando llega el pulso */
  .nodes circle {
    opacity: 0.35;
    animation: fx-node 8s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes fx-node {
    0%, 55%  { opacity: 0.35; }
    68%      { opacity: 1; }
    80%, 100% { opacity: 0.35; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulses path, .nodes circle {
      animation: none;
    }
    .pulses {
      display: none;
    }
  }

  /* en móvil la capa baja de intensidad para no competir con el texto */
  @media (max-width: 640px) {
    .herofx {
      opacity: 0.35;
    }
  }
</style>
