---
/*
  Animación para EnerLabsQ: ondas de señal estilo osciloscopio que se
  dibujan de izquierda a derecha y se desvanecen, en loop desfasado.
  Solo SVG + CSS. Se monta como capa absoluta dentro del header de página.
*/
---

<div class="wavefx" aria-hidden="true">
  <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" fill="none">
    <defs>
      <linearGradient id="wave-g" x1="0" y1="0" x2="1200" y2="0" gradientUnits="userSpaceOnUse">
        <stop stop-color="#3EC7A6" />
        <stop offset="1" stop-color="#38BDF8" />
      </linearGradient>
    </defs>

    <!-- línea base del osciloscopio -->
    <line x1="0" y1="200" x2="1200" y2="200" stroke="#3EC7A6" stroke-width="1" opacity="0.12" />

    <!-- ondas: se dibujan y desvanecen, desfasadas -->
    <path
      class="wave"
      pathLength="100"
      style="--dur: 7s; --delay: 0s"
      stroke="url(#wave-g)"
      stroke-width="2.5"
      stroke-linecap="round"
      d="M -20 200 C 60 110, 140 110, 220 200 S 380 290, 460 200 S 620 110, 700 200 S 860 290, 940 200 S 1100 110, 1180 200 S 1280 250, 1320 200"
    />
    <path
      class="wave"
      pathLength="100"
      style="--dur: 8.5s; --delay: 2.8s"
      stroke="#38BDF8"
      stroke-width="1.8"
      stroke-linecap="round"
      opacity="0.8"
      d="M -20 230 C 40 180, 100 180, 160 230 S 280 280, 340 230 S 460 180, 520 230 S 640 280, 700 230 S 820 180, 880 230 S 1000 280, 1060 230 S 1180 180, 1240 230"
    />
    <path
      class="wave"
      pathLength="100"
      style="--dur: 10s; --delay: 5.2s"
      stroke="#3EC7A6"
      stroke-width="1.4"
      stroke-linecap="round"
      opacity="0.6"
      d="M -20 165 C 80 140, 160 190, 260 165 S 440 140, 540 165 S 720 190, 820 165 S 1000 140, 1100 165 S 1240 185, 1320 165"
    />
  </svg>
</div>

<style>
  .wavefx {
    position: absolute;
    inset: 0;
    opacity: 0.5;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
  }
  .wavefx svg {
    width: 100%;
    height: 100%;
  }

  /* la onda se dibuja (dashoffset), sostiene y se desvanece */
  .wave {
    stroke-dasharray: 100 100;
    stroke-dashoffset: 100;
    animation: wave-draw var(--dur, 8s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }
  @keyframes wave-draw {
    0%        { stroke-dashoffset: 100; opacity: 1; }
    55%       { stroke-dashoffset: 0;   opacity: 1; }
    72%       { opacity: 1; }
    88%, 100% { stroke-dashoffset: 0;   opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wave {
      animation: none;
      stroke-dashoffset: 0;
      opacity: 0.5;
    }
  }
</style>
