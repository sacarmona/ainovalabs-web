---
import t from '../content/i18n/es.json';
import site from '../content/site.json';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-navy-900">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 md:grid-cols-4 md:px-8">
    <div class="md:col-span-2">
      <Logo size={40} />
      <p class="mt-3 max-w-md text-sm leading-relaxed text-ink-400">{t.footer.tagline}</p>
    </div>

    {t.footer.columns.map((col) => (
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-ink-300">{col.title}</p>
        <ul class="mt-4 space-y-2.5">
          {col.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-ink-400 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-ink-300">{t.footer.contactTitle}</p>
      <ul class="mt-4 space-y-2.5 text-sm text-ink-400">
        <li><a href={`mailto:${site.email}`} class="transition-colors hover:text-white">{site.email}</a></li>
        {site.phones.map((phone) => <li>{phone}</li>)}
        <li class="leading-relaxed">{site.address}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 py-5 text-center text-xs text-ink-400">
    © {year} {site.name}. {t.footer.rights}
  </div>
</footer>
