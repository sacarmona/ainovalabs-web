---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBand from '../components/CtaBand.astro';
import t from '../content/i18n/es.json';

export function getStaticPaths() {
  return Object.keys(t.pages).map((page) => ({ params: { page } }));
}

const { page } = Astro.params;
const data = t.pages[page as keyof typeof t.pages];
---

<Base title={`${data.title} — AI-NOVA Labs`} description={data.intro}>
  <PageHeader title={data.title} intro={data.intro} />

  <section class="pb-20 md:pb-28">
    <div class="mx-auto grid max-w-7xl gap-6 px-5 md:grid-cols-3 md:px-8">
      {data.sections.map((section, i) => (
        <div class="reveal rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <p class="font-display text-4xl font-bold text-gradient">{String(i + 1).padStart(2, '0')}</p>
          <h2 class="mt-4 font-display text-2xl font-bold">{section.title}</h2>
          <p class="mt-3 leading-relaxed text-ink-400">{section.text}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBand />
</Base>
